{
  "name": "maya-ui-monorepo",
  "private": true,
  "workspaces": [
    "maya",
    "sample-maya-app",
    "brahma"
  ],
  "scripts": {
    "dev": "bun ./src/dev/run-dev.ts && bun run clean && bun i",
    "dev:exit": "bun ./src/dev/exit-dev.ts",
    "dev:modecheck": "bun ./src/dev/mode-check.ts",
    "clean:modules": "rm -rf node_modules maya/node_modules brahma/node_modules sample-maya-app/node_modules",
    "clean:packagejsonlocks": "rm -f package-lock.json maya/package-lock.json brahma/package-lock.json sample-maya-app/package-lock.json",
    "clean:bunlocks": "rm -f bun.lock maya/bun.lock brahma/bun.lock sample-maya-app/bun.lock",
    "clean:bunlockbs": "rm -f bun.lockb maya/bun.lockb brahma/bun.lockb sample-maya-app/bun.lockb",
    "clean:locks": "bun run clean:packagejsonlocks && bun run clean:bunlocks && bun run clean:bunlockbs",
    "clean:cache": "rm -rf ~/.bun/install/cache",
    "clean": "bun run clean:modules && bun run clean:locks",
    "publish": "bun run ./src/publish/index.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@cyftec/brahma": "link:@cyftec/brahma"
  }
}